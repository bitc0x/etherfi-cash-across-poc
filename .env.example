# ─── Across (required for live quotes) ─────────────────────────────────────────
# Server-side only. Never commit a real key; set it in Vercel env / .env.local.
# Quotes work without a key (rate-limited, no attribution); set it for production.
ACROSS_API_KEY=
# ether.fi's pre-provisioned integrator ID. Volume attributes to this ID.
ACROSS_INTEGRATOR_ID=0x0162

# ─── Destination liquidity sources (optional) ─────────────────────────────────
# Bebop RFQ: used by /api/build-deposit and /api/bebop-quote. Without it the
# Bebop path is heavily rate-limited and prices are worse (per Bebop docs).
BEBOP_API_KEY=
# 1inch dev-portal key: required for the 1inch Aggregation and 1inch Fusion
# paths (/api/oneinch-quote, /api/fusion-*). Without it those sources are
# disabled; Bebop RFQ still works.
ONEINCH_API_KEY=

# ─── Async order-tracking layer (optional) ────────────────────────────────────
# Base URL of the across-order-tracking deployment. When set, the Fusion path
# fires a fire-and-forget POST to {URL}/api/order/submit after the deposit is
# mined so the order's async state is tracked. Unset → the PoC skips it and
# behaves identically.
NEXT_PUBLIC_TRACKING_URL=

# ─── Wallet (optional) ─────────────────────────────────────────────────────────
# WalletConnect project ID for RainbowKit. Falls back to a demo ID if unset.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
